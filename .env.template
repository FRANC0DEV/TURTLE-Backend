#========================================PRISMA ENVIRONMENT VARIABLES=========================================

# Environment variables declared in this file are NOT automatically loaded by Prisma. To load env variables
# in a Nest.js project it was necessary to import a Config Module in the App module.

# For more information visit: https://docs.nestjs.com/recipes/prisma#set-up-prisma

# Url that delivers the datasource necessary for Prisma's introspection & migration commands
DATABASE_URL=postgresql://prisma_user:prisma_password@localhost:5432/turtledb?schema=public
# Port where the backend runs
PORT=3000
#=================================POSTGRES IMAGE ENVIRONMENT VARIABLES============================

# For more information visit: https://hub.docker.com/_/postgres#how-to-extend-this-image

#Host port offered to the postgres service in port mapping (do not name it like envs from the image docs)
HOST_POSTGRES_PORT=5432
# Default user with super-user powers created when the postgres image is first started
POSTGRES_USER=postgres
# Password created when the postgres image is first started, the password for the POSTGRES_USER
POSTGRES_PASSWORD=VYhNyDk2wBLGcbkxPKfb
# Name for the default database that is created when the image is first started.
POSTGRES_DB=turtledb



#=================================PGADMIN IMAGE ENVIRONMENT VARIABLES============================

# For more information visit: https://www.pgadmin.org/docs/pgadmin4/latest/container_deployment.html#environment-variables

# Note: The following variables have nothing to do with the users defined inside the database.
#       This credentials are just to access the pgAdmin web UI

#Host port offered to the pgadmin service in port mapping (do not name it like envs from the image docs)
HOST_PGADMIN_PORT=80
# Email address used when setting up the initial administrator account to login to pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
# Password used when setting up the initial administrator account to login to pgAdmin. 
PGADMIN_DEFAULT_PASSWORD=admin_password
