generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model warehouse {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  description String?
  address     String  @db.VarChar(255)
}
