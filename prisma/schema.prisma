enum contact_method_type {
  email
  phone
  WhatsApp
}

enum customer_order_item_status_type {
  pending
  preparing
  finished
}

enum customer_order_payment_status_type {
  pending
  paid
}

enum customer_order_status_type {
  pending
  preparing
  on_the_way @map("on the way")
  delivered
}

enum customer_order_type {
  dine_in  @map("dine in")
  take_out @map("take out")
  delivery
}

enum menu_item_status_type {
  available
  out_of_stock @map("out of stock")
  discontinued
}

enum menu_item_type {
  combo
