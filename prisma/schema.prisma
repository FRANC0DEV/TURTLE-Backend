generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model combo_description {
  combo_description_id                                   Int        @id(map: "combo_description_pk") @default(autoincrement())
  equivalence_factor                                     Decimal    @db.Decimal
  menu_item_id                                           Int
  combo_item_id                                          Int
  menu_items_combo_description_combo_item_idTomenu_items menu_items @relation("combo_description_combo_item_idTomenu_items", fields: [combo_item_id], references: [menu_item_id], onDelete: Cascade, onUpdate: NoAction, map: "combo_description_menu_items_combo_fk")
  menu_items_combo_description_menu_item_idTomenu_items  menu_items @relation("combo_description_menu_item_idTomenu_items", fields: [menu_item_id], references: [menu_item_id], onDelete: Cascade, onUpdate: NoAction, map: "combo_description_menu_items_fk")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model customer_order {
  customer_order_id    Int                                @id(map: "customer_order_pk") @default(autoincrement())
  created_at           DateTime                           @default(now()) @db.Timestamp(6)
  payment_status       customer_order_payment_status_type @default(pending)
  status               customer_order_status_type         @default(pending)
  subtotal             Decimal                            @default(0.00) @db.Decimal(10, 2)
  tax                  Decimal                            @default(0.00) @db.Decimal(10, 2)
  customer_name        String                             @db.VarChar
  customer_id          String                             @db.VarChar
  restaurant_table_id  Int?
  order_type           customer_order_type
  restaurant_table     restaurant_table?                  @relation(fields: [restaurant_table_id], references: [restaurant_table_id], onDelete: Restrict, onUpdate: NoAction, map: "customer_order_restaurant_table_fk")
  customer_order_items customer_order_items[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model customer_order_items {
  customer_order_item_id Int                             @id(map: "customer_order_details_pk") @default(autoincrement())
  quantity               Int                             @db.SmallInt
  customer_comments      String?                         @db.VarChar
  status                 customer_order_item_status_type @default(pending)
  customer_order_id      Int
  menu_item_id           Int
  customer_order         customer_order                  @relation(fields: [customer_order_id], references: [customer_order_id], onDelete: Cascade, onUpdate: NoAction, map: "customer_order_items_customer_order_fk")
  menu_items             menu_items                      @relation(fields: [menu_item_id], references: [menu_item_id], onUpdate: NoAction, map: "customer_order_items_menu_items_fk")
}

